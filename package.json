{
  "name": "pixiv-filter-for-wxt",
  "description": "PixivでNG登録したユーザーやタグの作品を非表示にします。",
  "private": true,
  "version": "1.7.1",
  "type": "module",
  "scripts": {
    "dev": "pnpm wxt",
    "dev:firefox": "wxt -b firefox",
    "dev:brave": "wxt -b brave",
    "build": "wxt build",
    "build:firefox": "wxt build -b firefox",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip -b firefox",
    "compile": "tsc --noEmit",
    "postinstall": "wxt prepare",
    "esbuild": "node esbuild.config.mjs",
    "test": "pnpm build && playwright test",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.58.2",
    "@types/chrome": "^0.1.38",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/wicg-file-system-access": "^2023.10.7",
    "@wxt-dev/module-react": "^1.2.2",
    "concurrently": "^9.2.1",
    "esbuild": "^0.27.4",
    "eslint": "^10.1.0",
    "eslint-plugin-react": "^7.37.5",
    "globals": "^17.4.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.57.2",
    "wxt": "^0.20.20"
  },
  "pnpm": {
    "overrides": {
      "vite": "^7.1.11",
      "js-yaml": "^4.1.1",
      "picomatch": ">=4.0.4",
      "node-forge": ">=1.4.0",
      "minimatch": ">=3.1.4",
      "flatted": ">=3.4.2",
      "rollup": ">=4.59.0",
      "brace-expansion": ">=5.0.5"
    }
  }
}
